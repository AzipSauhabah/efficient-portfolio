# Data — garde les parquet en cache mais pas les fichiers trop lourds
data/cache/*.pkl          # modèles ML (trop lourds pour git)
data/cache/tb_logs/       # TensorBoard logs
data/raw/

# Sauf ces fichiers de cache légers (données pré-calculées pour Colab)
!data/cache/.gitkeep
!data/cache/universe_latest.parquet
!data/cache/update_manifest.json

